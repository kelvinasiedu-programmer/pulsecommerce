# Copy this file to secrets.toml and fill in values before deploying.
# secrets.toml is gitignored — never commit real secrets.

# Example: a read-only DB URL, an API key for optional integrations, etc.
# No secrets are required for the default synthetic-data deployment.

# [database]
# url = "postgres://..."

# [tracking]
# posthog_api_key = "phc_..."
